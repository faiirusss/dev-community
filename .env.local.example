# Deployment used by `npx convex dev`
# Get this from your Convex dashboard: https://dashboard.convex.dev
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Convex URL - auto-generated from your deployment
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex Site URL - auto-generated from your deployment
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devto_db

# Better Auth - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long

# Better Auth - base URL of your app
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth - create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
